# Copy this file to secrets.env and fill in real values.
# secrets.env is gitignored and must never be committed.

# OpenRouter API key — injected into env containers at docker run time.
# Create at https://openrouter.ai/keys
OPENROUTER_KEY=sk-or-...

# DigitalOcean API token — used by agentspace.py to manage droplets.
# Create at https://cloud.digitalocean.com/account/api/tokens
# Not needed for MVP-of-MVP (single-box, no doctl calls).
DO_TOKEN=dop_v1_...
