{
  // simple2agent 4.0: 2 agents, message-yes/read-no isolation, BOTH layers closed:
  // session tools (visibility=all + per-agent deny) AND filesystem (per-agent
  // docker sandboxes). __ENV__ → env name, rewritten by `snap fork`; workspace
  // paths are HOST-namespace (host daemon resolves sandbox mounts; path rule).
  // Rationale/quirks: docs/runtime_openclaw.md. Keep comments SHORT (size-drop guard).
  // OPENROUTER_API_KEY is injected at runtime via docker run -e.
  gateway: {
    mode: "local",
    auth: {
      mode: "token",
      token: "agentspace",
    },
  },

  agents: {
    defaults: {
      model: {
        primary: "openrouter/anthropic/claude-haiku-4-5",
      },
      heartbeat: { every: "240m" },
      // OC bug: sessionToolsVisibility is read ONLY from defaults-level sandbox.
      // containerPrefix: OC's sandbox name hash IGNORES the workspace path, so
      // without a per-env prefix two envs from one snap silently SHARE sandboxes.
      sandbox: {
        sessionToolsVisibility: "all",
        docker: { containerPrefix: "openclaw-sbx-__ENV__-" },
      },
    },
    list: [
      {
        id: "a87329",
        name: "Agent 87329",
        workspace: "/var/agentspace-envs/__ENV__/a87329/workspace",
        agentDir: "/var/agentspace-envs/__ENV__/a87329/agent",
        sandbox: { mode: "all", scope: "agent", workspaceAccess: "rw" },
        tools: {
          deny: ["sessions_history", "sessions_list", "session_status"],
        },
      },
      {
        id: "a90301",
        name: "Agent 90301",
        workspace: "/var/agentspace-envs/__ENV__/a90301/workspace",
        agentDir: "/var/agentspace-envs/__ENV__/a90301/agent",
        sandbox: { mode: "all", scope: "agent", workspaceAccess: "rw" },
        tools: {
          deny: ["sessions_history", "sessions_list", "session_status"],
        },
      },
    ],
  },

  session: {
    // 0 kills the automatic A2A reply-loop (budget storms + privacy leak).
    agentToAgent: { maxPingPongTurns: 0 },
  },

  tools: {
    agentToAgent: {
      enabled: true,
      allow: ["a87329", "a90301"],
    },
    sessions: {
      visibility: "all",
    },
  },
}
