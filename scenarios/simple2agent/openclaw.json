{
  // 2 agents; message-yes/read-no isolation: visibility=all (required for cross-agent
  // sessions_send) + per-agent tools.deny of sessions_history/list. Peer session keys
  // are baked into each workspace's PEERS.md since discovery (sessions_list) is denied.
  // !! ISOLATION IS PARTIAL: both agents share one container as the same OS user, so
  // !! fs/exec tools can read the peer's workspace, memory, and session files directly.
  // !! Don't rely on privacy for adversarial scenarios until that hole is closed.
  // Full rationale: docs/agentspace_cli.md "Feature flags" section.
  // NOTE: keep comments SHORT — `openclaw config set` strips them on rewrite, and
  // OpenClaw rejects writes that shrink the file too much (size-drop guard).
  // OPENROUTER_API_KEY is injected at runtime via docker run -e.
  gateway: {
    mode: "local",
    auth: {
      mode: "token",
      token: "agentspace",
    },
  },

  agents: {
    defaults: {
      model: {
        primary: "openrouter/anthropic/claude-haiku-4-5",
      },
    },
    list: [
      {
        id: "a87329",
        name: "Agent 87329",
        workspace: "/data/openclaw/agents/a87329/workspace",
        agentDir: "/data/openclaw/agents/a87329/agent",
        tools: {
          deny: ["sessions_history", "sessions_list", "session_status"],
        },
      },
      {
        id: "a90301",
        name: "Agent 90301",
        workspace: "/data/openclaw/agents/a90301/workspace",
        agentDir: "/data/openclaw/agents/a90301/agent",
        tools: {
          deny: ["sessions_history", "sessions_list", "session_status"],
        },
      },
    ],
  },

  tools: {
    agentToAgent: {
      enabled: true,
      allow: ["a87329", "a90301"],
    },
    sessions: {
      visibility: "all",
    },
  },
}
