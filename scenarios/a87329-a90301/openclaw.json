{
  // OPENROUTER_API_KEY is injected at runtime via docker run -e.
  // openclaw.json is inside the image; the key is never baked in.
  // Required: gateway refuses to start without this.
  gateway: {
    mode: "local",
  },

  agents: {
    defaults: {
      model: {
        // Use date-free model IDs so the snap doesn't go stale.
        // Format: openrouter/<provider>/<model-id>
        primary: "openrouter/anthropic/claude-haiku-4-5",
      },
    },
    list: [
      {
        id: "a87329",
        name: "Agent 87329",
        workspace: "/data/openclaw/agents/a87329/workspace",
        agentDir: "/data/openclaw/agents/a87329/agent",
      },
      {
        id: "a90301",
        name: "Agent 90301",
        workspace: "/data/openclaw/agents/a90301/workspace",
        agentDir: "/data/openclaw/agents/a90301/agent",
      },
    ],
  },

  // Tool policy: messaging profile (sessions_list, sessions_history,
  // sessions_send, session_status) plus read/write for scratchpads.
  // No exec, no web, no external channels.
  tools: {
    profile: "messaging",
    allow: ["read", "write", "sessions_list", "sessions_history", "sessions_send", "session_status"],
    agentToAgent: {
      enabled: true,
      allow: ["a87329", "a90301"],
    },
    sessions: {
      // "all" lets each agent see and target the other's sessions.
      visibility: "all",
    },
  },
}
